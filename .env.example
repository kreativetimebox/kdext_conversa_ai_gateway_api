ENVIRONMENT=local
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001

# Local development can use SQLite. Production must use PostgreSQL.
DATABASE_URL=sqlite:///./voice_gateway.db
# DATABASE_URL=postgresql+psycopg2://voicegw:change-me@localhost:5432/voice_gateway

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES=3600

# Use false in production and run: alembic upgrade head
CREATE_DB_TABLES=true

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001

TTS_ENGINE_URL=http://localhost:8000
TTS_ENGINE_PATH=/v1/tts
TTS_ALLOWED_FORMATS=wav
MAX_TTS_TEXT_CHARS=1000

# Leave empty for development stub. Set this in production when the STT engine is available.
STT_ENGINE_URL=
STT_ENGINE_PATH=/v1/stt
ENGINE_TIMEOUT_SECONDS=60

AUDIO_STORAGE_DIR=audio_storage
MAX_AUDIO_UPLOAD_BYTES=26214400
ALLOWED_AUDIO_CONTENT_TYPES=audio/wav,audio/wave,audio/x-wav,audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/webm,audio/ogg
