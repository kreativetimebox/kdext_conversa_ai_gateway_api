ENVIRONMENT=local
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
# Local development — SQLite (no extra setup needed)
DATABASE_URL=sqlite:///./voice_gateway.db

# Production — AWS RDS PostgreSQL
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
# Example:
# DATABASE_URL=postgresql+psycopg2://voicegw:YourPassword@voice-gateway.xxxx.ap-south-1.rds.amazonaws.com:5432/voice_gateway

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES=3600

# Use false in production and run: alembic upgrade head
CREATE_DB_TABLES=true

# Set to true in production to remove unauthenticated /demo/* routes
DISABLE_DEMO=false

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001

# ──────────────────────────────────────────────────────────────────────────────
# VOICE ENGINES
# ──────────────────────────────────────────────────────────────────────────────
TTS_ENGINE_URL=http://localhost:8000
TTS_ENGINE_PATH=/v1/tts
TTS_ALLOWED_FORMATS=wav
MAX_TTS_TEXT_CHARS=1000

# Leave empty for development stub. Set this in production when STT engine is available.
STT_ENGINE_URL=
STT_ENGINE_PATH=/v1/stt
ENGINE_TIMEOUT_SECONDS=60

# ──────────────────────────────────────────────────────────────────────────────
# AUDIO STORAGE
# ──────────────────────────────────────────────────────────────────────────────
MAX_AUDIO_UPLOAD_BYTES=26214400
ALLOWED_AUDIO_CONTENT_TYPES=audio/wav,audio/wave,audio/x-wav,audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/webm,audio/ogg

# Local disk storage (used when USE_S3_STORAGE=false)
AUDIO_STORAGE_DIR=audio_storage

# ──────────────────────────────────────────────────────────────────────────────
# AWS S3 — Audio file storage (TTS output + STT uploads)
# ──────────────────────────────────────────────────────────────────────────────
# Set USE_S3_STORAGE=true to enable S3. All four vars below are then required.
USE_S3_STORAGE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=voice-gateway-audio
# Bucket region — use ap-south-1 for India, us-east-1 for US, eu-west-1 for EU
AWS_S3_REGION=ap-south-1
