ENVIRONMENT=local
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
# Local development — SQLite (no extra setup needed)
DATABASE_URL=sqlite:///./voice_gateway.db

# Production — AWS RDS PostgreSQL
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
# Example:
# DATABASE_URL=postgresql+psycopg2://voicegw:YourPassword@voice-gateway.xxxx.ap-south-1.rds.amazonaws.com:5432/voice_gateway

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES=3600

# Use false in production and run: alembic upgrade head
CREATE_DB_TABLES=true

# Set to true in production to remove unauthenticated /demo/* routes
DISABLE_DEMO=false

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001,http://185.14.252.20:8004

# ──────────────────────────────────────────────────────────────────────────────
# LLM SERVICE (chatbot microservice) — proxied through /api/* and /v1/*
# ──────────────────────────────────────────────────────────────────────────────
# The gateway reverse-proxies chat, translation, and voice (Edge/Bing TTS + STT)
# to this microservice, adding API-key management on top. Point it at wherever
# the chatbot LLM service runs.
LLM_SERVICE_URL=http://185.14.252.20:8008
LLM_SERVICE_TIMEOUT=120
# Require a gateway X-API-Key on the proxied LLM routes.
# true (default) = one gateway API key unlocks ALL features (chat, translate,
# voice, history). Internal hops stay keyless: gateway → LLM service → vLLM (llama).
# Set false only for an open/no-auth demo.
LLM_REQUIRE_API_KEY=true
# Shared secret sent to the LLM service (X-Service-Key) — must equal the LLM
# service's SERVICE_API_KEY. Blocks direct-IP bypass of the gateway.
LLM_SERVICE_API_KEY=change-me-to-a-long-random-secret
# Per-user rate limiting on the model (protects the GPU from abuse).
LLM_RATE_LIMIT_ENABLED=false

# DB connection pool (per worker) — raise for higher concurrency.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# ──────────────────────────────────────────────────────────────────────────────
# VOICE ENGINES (gateway's own Parler /text-to-speech + /demo/tts routes)
# ──────────────────────────────────────────────────────────────────────────────
# NOTE: the chatbot's /api/voice/tts uses Edge/Bing neural TTS inside the LLM
# service — it does NOT use TTS_ENGINE_URL below.
TTS_ENGINE_URL=http://localhost:8000
TTS_ENGINE_PATH=/v1/tts
TTS_ALLOWED_FORMATS=wav
MAX_TTS_TEXT_CHARS=500

# Leave empty for development stub. Set this in production when STT engine is available.
STT_ENGINE_URL=
STT_ENGINE_PATH=/v1/stt
ENGINE_TIMEOUT_SECONDS=60

# ──────────────────────────────────────────────────────────────────────────────
# AUDIO STORAGE
# ──────────────────────────────────────────────────────────────────────────────
MAX_AUDIO_UPLOAD_BYTES=26214400
ALLOWED_AUDIO_CONTENT_TYPES=audio/wav,audio/wave,audio/x-wav,audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/webm,audio/ogg

# Local disk storage (used when USE_S3_STORAGE=false)
AUDIO_STORAGE_DIR=audio_storage

# ──────────────────────────────────────────────────────────────────────────────
# AWS S3 — Audio file storage (TTS output + STT uploads)
# ──────────────────────────────────────────────────────────────────────────────
# Set USE_S3_STORAGE=true to enable S3. All four vars below are then required.
USE_S3_STORAGE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=voice-gateway-audio
# Bucket region — use ap-south-1 for India, us-east-1 for US, eu-west-1 for EU
AWS_S3_REGION=ap-south-1



# ──────────────────────────────────────────────────────────────────────────────
# AMAZON SQS — Async Job Queue (voice-worker microservice)
# ──────────────────────────────────────────────────────────────────────────────
# Set USE_ASYNC_QUEUE=true to enable async job processing.
# When enabled, TTS/STT requests are queued in SQS and processed by the
# separate voice-worker microservice. Clients poll GET /jobs/{job_id} for results.
USE_ASYNC_QUEUE=false
AWS_SQS_REGION=ap-southeast-2
AWS_SQS_TTS_QUEUE_URL=
AWS_SQS_STT_QUEUE_URL=

# ── RATE LIMITS ───────────────────────────────────────────────────────────────
LLM_RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=50
RATE_LIMIT_RPD=1000
